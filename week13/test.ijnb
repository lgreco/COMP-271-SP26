      "id": "919ad6fe-7bee-4346-b416-94ed2e5817fb",
      "cell_type": "code",
      "source": "public class Node {\n    \n    private String value;\n    private Node next;\n\n    public Node(String value) {\n        this.value = value;\n        this.next = null;\n    }\n\n    public String getValue() {\n        return this.value;\n    }\n\n    public Node getNext() {\n        return this.next;\n    }\n\n    public void setNext(Node next) {\n        this.next = next;\n    }\n}",
      "metadata": {
        "language": "java",
        "executionSummary": {
          "executionOrder": 4,
          "success": true
        }
