    {
      "id": "e115b7a2-a42b-4ede-8217-7a55aad7f1ef",
      "cell_type": "code",
      "source": "public class LinkedList {\n\n    private Node head;\n    private Node tail;\n    private int count;\n\n    public LinkedList() {\n        this.head = null;\n        this.tail = null;\n        this.count = 0;\n    }\n\n    /**\n     * Add a node to the linked list\n     * \n     * @param value String for which we create a\n     *              new node and append it to the end of the list.\n     */\n    public void addNode(String value) {\n        // Create the new node:\n        Node newNode = new Node(value);\n        // If list is empty, new node becomes head,\n        // otherwise, we appended to the tail node\n        if (this.count == 0) {\n            this.head = newNode;\n        } else {\n            this.tail.setNext(newNode);\n        }\n        this.tail = newNode;\n        this.count++; // same as this.count = this.count+1\n    }\n}",
      "metadata": {
        "language": "java",
        "id": "e115b7a2-a42b-4ede-8217-7a55aad7f1ef",
        "executionSummary": {
          "executionOrder": 5,
